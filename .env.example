# Copy this file to .env and fill in real values locally.
# Never commit .env.
APP_ENV=local
LOG_LEVEL=INFO

# Stage 1: OpenAI + Pinecone connection checks
OPENAI_API_KEY=
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_CONFIDENCE_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=customer-support-simple-rag

# Match the Week 2 notebooks unless we intentionally change it later.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512
CHAT_MODEL=gpt-4.1-mini
RETRIEVAL_TOP_K=5
HYBRID_SEMANTIC_K=3
HYBRID_BM25_K=3
HYBRID_SEMANTIC_WEIGHT=0.5
HYBRID_BM25_WEIGHT=0.5
CONFIDENCE_PROVIDER=nebius
CONFIDENCE_THRESHOLD=0.65
CONFIDENCE_MIN_SOURCES=2

# Stage 1: simple RAG offline ingestion defaults
CHUNK_SIZE=500
CHUNK_OVERLAP=100
